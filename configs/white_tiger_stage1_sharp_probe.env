# Sharp-fur diagnostic probe for the white tiger Stage 1 long-streak issue.
# This is not the formal baseline config. It sources the formal config first and
# only changes objective weights / learning rates to test whether long dark
# streaks are caused by RGB-dominant, over-flexible strand geometry.

CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=white_tiger_stage1_formal.env
source "$CONFIG_DIR/white_tiger_stage1_formal.env"

# Make RGB less able to pull geometry into black paint strokes.
RGB_WEIGHT=0.45
RANDOM_BACKING_LOSS_WEIGHT=0.15

# Make rendered strand orientation and image-space strand structure matter more.
ORIENTATION_WEIGHT=0.12
ORIENTATION_DETAIL_WEIGHT=0.08

# Make neighboring roots/strands stay more hair-like and less noisy.
SMOOTH_WEIGHT=0.08
STRAND_SHAPE_SMOOTH_WEIGHT=0.10
SHAPE_PRIOR_WEIGHT=0.15

# Slow down high-frequency shape parameters that can create curly/noisy streaks.
LR_GROOM=0.010
LR_HIGH_FREQUENCY_SHAPE_SCALE=0.12

# Keep densification identical to formal config for this probe.

# Ablation: disable render-root densification.
#
# Purpose:
# - same view09, full resolution, 3200 iterations as the 38+ baseline;
# - keeps delayed guide residual unlock active;
# - disables render-root and guide-root densification to isolate whether the
#   38+ result mainly comes from root lifecycle coverage growth.
source "$(dirname "${BASH_SOURCE[0]}")/white_tiger_stage1_multiroot_stageab_100k_lowguide_view09.env"

DENSIFY_UNTIL=0
MAX_SPLITS_PER_EVENT=0
GUIDE_DENSIFY_UNTIL=0
GUIDE_DENSIFY_MAX_SPLITS_PER_EVENT=0
PRUNE_START=999999
PRUNE_INTERVAL=0

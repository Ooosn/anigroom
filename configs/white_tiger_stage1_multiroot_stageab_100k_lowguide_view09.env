# Formal candidate: 100k render roots, low guide roots, delayed guide densification.
# This is the active Stage1 route for the 38+ checkpoint.
source "$(dirname "${BASH_SOURCE[0]}")/white_tiger_stage1_multiroot.env"

ROOT_COUNT=100000
GUIDE_ROOT_COUNT=2048
CHILD_COUNT=4

ITERATIONS=3200
EVAL_EVERY=200
SAVE_EVERY=800
TRAIN_VIEWS=9
TEST_VIEWS=9

INIT_GROOM_LENGTH=0.034
INIT_GUIDE_LENGTH=0.034

SAMPLES=64
MIN_SEGMENTS=10
MAX_SEGMENTS=36

GUIDE_CONTROLS_FLOW=1
GUIDE_LENGTH_RESIDUAL_SCALE=0.00
GUIDE_BEND_RESIDUAL_SCALE=0.08
GUIDE_FLOW_RESIDUAL_SCALE=0.10
GUIDE_WIDTH_RESIDUAL_SCALE=0.06
GUIDE_FLOW_STRENGTH_RESIDUAL_SCALE=0.08
GUIDE_LIFT_RESIDUAL_SCALE=0.08
GUIDE_STIFFNESS_RESIDUAL_SCALE=0.08
GUIDE_CHILD_RADIUS_RESIDUAL_SCALE=0.04
GUIDE_CLUMP_RESIDUAL_SCALE=0.04
GUIDE_CURL_RESIDUAL_SCALE=0.04
GUIDE_FRIZZ_RESIDUAL_SCALE=0.03
GUIDE_RESIDUAL_INITIAL_MULTIPLIER=0.0
GUIDE_RESIDUAL_UNLOCK_START=1800
GUIDE_RESIDUAL_UNLOCK_END=3200
GUIDE_FREEZE_UNTIL=0

GUIDE_SMOOTH_WEIGHT=0.090
SMOOTH_WEIGHT=0.016
STRAND_SHAPE_SMOOTH_WEIGHT=0.003
SHAPE_PRIOR_WEIGHT=0.018
EFFECTIVE_GEOMETRY_BUDGET_WEIGHT=0.120
EFFECTIVE_LENGTH_TARGET=0.052
EFFECTIVE_WIDTH_TARGET=0.00042
EFFECTIVE_CHILD_RADIUS_TARGET=0.0015
GUIDE_PRIOR_WEIGHT=0.060
GUIDE_PRIOR_FLOW_WEIGHT=1.0
GUIDE_PRIOR_BEND_WEIGHT=0.28
GUIDE_PRIOR_LIFT_WEIGHT=0.22
GUIDE_PRIOR_STIFFNESS_WEIGHT=0.15
GUIDE_PRIOR_CURL_WEIGHT=0.15
GUIDE_PRIOR_LENGTH_WEIGHT=2.40
GUIDE_PRIOR_WIDTH_WEIGHT=0.35
GUIDE_PRIOR_CHILD_RADIUS_WEIGHT=0.20
GUIDE_PRIOR_CLUMP_WEIGHT=0.12

LR_GROOM=0.012
LR_HIGH_FREQUENCY_SHAPE_SCALE=0.25
LR_COLOR=0.020
LR_ROOT=0.00070
ROOT_MOVE_REG_WEIGHT=0.003

RGB_WEIGHT=1.0
RANDOM_BACKING_LOSS_WEIGHT=0.25
MASK_WEIGHT=0.08
ORIENTATION_WEIGHT=0.02
ORIENTATION_DETAIL_WEIGHT=0.02

EARLY_CAPACITY_WEIGHT=0.030
EARLY_CAPACITY_UNTIL=1000
EARLY_CAPACITY_LENGTH_TARGET=0.060
EARLY_CAPACITY_WIDTH_TARGET=0.00034
EARLY_CAPACITY_OPACITY_TARGET=0.88

# Render-root coverage grows first.
DENSIFY_WARMUP=200
DENSIFY_INTERVAL=100
DENSIFY_UNTIL=1700
DENSIFY_SCORE_THRESHOLD=2.5e-5
DENSIFY_MIN_CONTRIBUTION=0.45
DENSIFY_RESIDUAL_WEIGHT=1.0
DENSIFY_RESIDUAL_MODE=pixel_to_root
DENSIFY_RESIDUAL_ALPHA_WEIGHT=1.0
DENSIFY_RESIDUAL_RGB_WEIGHT=0.35
DENSIFY_PIXEL_EVIDENCE_TOPK=32768
DENSIFY_PIXEL_EVIDENCE_MIN=0.010
DENSIFY_PARENT_SELECTION=target_direct
DENSIFY_TARGET_PLACEMENT_WEIGHT=0.0
MAX_SPLITS_PER_EVENT=1536
SPLIT_CHILDREN_PER_PARENT=2
SPLIT_MIN_CHILD_DISTANCE=0.0012

# Guide roots densify only after render-root coverage has had time to stabilize.
GUIDE_DENSIFY_START=1800
GUIDE_DENSIFY_INTERVAL=100
GUIDE_DENSIFY_UNTIL=2600
GUIDE_DENSIFY_SCORE_THRESHOLD=2.5e-5
GUIDE_DENSIFY_MAX_SPLITS_PER_EVENT=256
GUIDE_DENSIFY_CHILDREN_PER_PARENT=1
GUIDE_DENSIFY_NEIGHBOR_COUNT=12
GUIDE_DENSIFY_CANDIDATE_RINGS=3
GUIDE_DENSIFY_CANDIDATE_FACE_COUNT=32
GUIDE_DENSIFY_MIN_CHILD_DISTANCE=0.003
GUIDE_DENSIFY_RENDER_ROOT_K=8

# No old hardcoded screen/dark/luma overlong route in the formal path.
OVERPAINT_CAPACITY_WEIGHT=0.0
DARK_STROKE_CAPACITY_WEIGHT=0.0
SCREEN_STROKE_CAPACITY_WEIGHT=0.0
NEUTRAL_SCREEN_CAPACITY_WEIGHT=0.0
COLOR_CONTRAST_CAPACITY_WEIGHT=0.0

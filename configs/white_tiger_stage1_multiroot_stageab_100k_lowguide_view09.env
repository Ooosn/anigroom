SCREEN_FOOTPRINT_SPLIT_DIAG_THRESHOLD=0
SCREEN_FOOTPRINT_SPLIT_EXTRA_PARENTS_PER_EVENT=0
SCREEN_FOOTPRINT_SPLIT_NEUTRAL_EXTRA_PARENTS_PER_EVENT=0

LOCAL_CHILD_COLOR_SUPPORT=0
LOCAL_CHILD_OPACITY_SUPPORT=0

PRUNE_START=999999

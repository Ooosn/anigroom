# Ablation: keep guide/render geometry residual locked for the whole run.
#
# Purpose:
# - same view09, full resolution, 3200 iterations as the 38+ baseline;
# - keeps render-root densification active;
# - disables the late guide residual unlock, isolating whether the 1800-3200
#   gain is real geometry/detail freedom or just longer training.
source "$(dirname "${BASH_SOURCE[0]}")/white_tiger_stage1_multiroot_stageab_100k_lowguide_view09.env"

GUIDE_RESIDUAL_INITIAL_MULTIPLIER=0.0
GUIDE_RESIDUAL_UNLOCK_START=999999
GUIDE_RESIDUAL_UNLOCK_END=1000000
GUIDE_DENSIFY_UNTIL=0
GUIDE_DENSIFY_MAX_SPLITS_PER_EVENT=0

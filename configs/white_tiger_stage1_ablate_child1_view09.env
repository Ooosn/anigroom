# Ablation: one child strand per render root.
#
# Purpose:
# - same view09, full resolution, 3200 iterations as the 38+ baseline;
# - tests whether child strands/clump-like local strand multiplicity is actually
#   useful, rather than only increasing Gaussian count.
source "$(dirname "${BASH_SOURCE[0]}")/white_tiger_stage1_multiroot_stageab_100k_lowguide_view09.env"

CHILD_COUNT=1
GUIDE_CHILD_RADIUS_RESIDUAL_SCALE=0.0
GUIDE_CLUMP_RESIDUAL_SCALE=0.0
GUIDE_PRIOR_CHILD_RADIUS_WEIGHT=0.0
GUIDE_PRIOR_CLUMP_WEIGHT=0.0
EFFECTIVE_CHILD_RADIUS_TARGET=0.0
